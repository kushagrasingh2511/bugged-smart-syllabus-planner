# MongoDB Atlas — use the connection string from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smart-syllabus-planner?retryWrites=true&w=majority

# If you see "querySrv ECONNREFUSED" on Windows, use Atlas "Standard" connection string
# or direct form: mongodb://<user>:<pass>@<shard-host>:27017/smart-syllabus-planner?ssl=true&authSource=admin&directConnection=true

# JWT secret for session tokens (use a long random string in production)
JWT_SECRET=your-secret-key-min-32-chars

# Google Gemini — official SDK reads GOOGLE_API_KEY (preferred) or GEMINI_API_KEY
# AQ-format authorization keys from AI Studio are supported (include dots)
GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_API_KEY=
# Optional: defaults to gemini-2.0-flash-lite (better free-tier quota)
GEMINI_MODEL=gemini-2.0-flash-lite

# Groq (free alternative to Gemini) — get a key at https://console.groq.com
# Uses Llama 3.3 70B for text and Llama 3.2 90B Vision for images
GROQ_API_KEY=your-groq-api-key-here

# AI provider: "groq" or "gemini" (auto-detects based on available keys if not set)
# AI_PROVIDER=groq

# Local folder for uploaded PDFs/images (default: ./uploads)
UPLOAD_DIR=

# App URL (optional, for production callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LAN dev: your machine IP when testing from phone/other device (allowedDevOrigins)
# DEV_ALLOWED_ORIGIN=10.71.127.94
