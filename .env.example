# MongoDB Atlas — use the connection string from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smart-syllabus-planner?retryWrites=true&w=majority

# If you see "querySrv ECONNREFUSED" on Windows, use Atlas "Standard" connection string
# or direct form: mongodb://<user>:<pass>@<shard-host>:27017/smart-syllabus-planner?ssl=true&authSource=admin&directConnection=true

# JWT secret for session tokens (use a long random string in production)
JWT_SECRET=your-secret-key-min-32-chars

# Google Gemini API (syllabus extraction)
GEMINI_API_KEY=
# Optional: defaults to gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# Local folder for uploaded PDFs/images (default: ./uploads)
UPLOAD_DIR=

# App URL (optional, for production callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
